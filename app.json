{
  "expo": {
    "name": "snapchef",
    "slug": "snapchef",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snapchef",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FBF5EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rsinha.snapchef"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FBF5EC"
      },
      "package": "com.rsinha.snapchef"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF5EC"
        }
      ],
      "expo-image",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b30d54c4-fa64-450b-856a-ea3af39ef924"
      }
    },
    "owner": "drnohan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b30d54c4-fa64-450b-856a-ea3af39ef924"
    }
  }
}
